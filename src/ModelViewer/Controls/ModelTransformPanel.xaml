<UserControl x:Class="ModelViewer.Controls.ModelTransformPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ModelViewer.Controls"
             xmlns:converters="clr-namespace:ModelViewer.Converters"
             x:ClassModifier="internal"
             Background="#2D2D30">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Border Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="4">
        <DockPanel>

            <!-- ── Collapsible Header ── -->
            <Border DockPanel.Dock="Top" Background="#252528"
                    BorderBrush="#3F3F46" BorderThickness="0,0,0,1"
                    Padding="6,5">
                <DockPanel>
                                        <!-- Collapse toggle (right side) -->
                    <Button Style="{StaticResource CollapseToggleButtonStyle}"
                            Command="{Binding ToggleExpandCommand}"
                            DockPanel.Dock="Right"
                            Width="18" Height="18"
                            Tag="Expanded">
                                                <Button.RenderTransform>
                            <RotateTransform Angle="{Binding ChevronAngle, Mode=OneWay}" />
                        </Button.RenderTransform>
                        <Button.RenderTransformOrigin>
                            <Point X="0.5" Y="0.5" />
                        </Button.RenderTransformOrigin>
                    </Button>
                    <!-- Title + selected model name -->
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Text="Transform" Foreground="White"
                                       FontWeight="SemiBold" FontSize="12"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                        <TextBlock Text="{Binding ModelName, Mode=OneWay}"
                                   Foreground="#888888" FontSize="10"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,1,0,0" />
                    </StackPanel>
                </DockPanel>
            </Border>

                        <!-- ── Collapsible Body ── -->
            <Grid Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}, Mode=OneWay}">
                <!-- Scrollable content -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="#2D2D30"
                              BorderThickness="0">
                    <StackPanel>
                        <WrapPanel Margin="0">

                            <!-- ════════════════════════════════════════════ -->
                            <!-- POSITION                                     -->
                            <!-- ════════════════════════════════════════════ -->
                            <StackPanel Margin="5">
                                <TextBlock Text="Position" Foreground="#007ACC"
                                           FontWeight="SemiBold" FontSize="12"
                                           Margin="0,4,0,2" />

                                <!-- X -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                    <TextBlock Text="X:" Foreground="#CCCCCC"
                                               FontSize="11" Width="16" />
                                                                        <TextBox Text="{Binding PosX, StringFormat=F3, UpdateSourceTrigger=PropertyChanged}"
                                             Width="60"
                                             Foreground="White" Background="#3F3F46"
                                             BorderBrush="#555555" BorderThickness="1"
                                             FontSize="11" Padding="2"
                                             TextAlignment="Right"
                                             IsEnabled="{Binding HasModel, Mode=OneWay}"
                                             Tag="X"
                                             local:DraggableNumberBehavior.IsEnabled="True"
                                             local:DraggableNumberBehavior.Sensitivity="0.05" />
                                </StackPanel>

                                <!-- Y -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                    <TextBlock Text="Y:" Foreground="#CCCCCC"
                                               FontSize="11" Width="16" />
                                                                        <TextBox Text="{Binding PosY, StringFormat=F3, UpdateSourceTrigger=PropertyChanged}"
                                             Width="60"
                                             Foreground="White" Background="#3F3F46"
                                             BorderBrush="#555555" BorderThickness="1"
                                             FontSize="11" Padding="2"
                                             TextAlignment="Right"
                                             IsEnabled="{Binding HasModel, Mode=OneWay}"
                                             Tag="Y"
                                             local:DraggableNumberBehavior.IsEnabled="True"
                                             local:DraggableNumberBehavior.Sensitivity="0.05" />
                                </StackPanel>

                                <!-- Z -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                    <TextBlock Text="Z:" Foreground="#CCCCCC"
                                               FontSize="11" Width="16" />
                                                                        <TextBox Text="{Binding PosZ, StringFormat=F3, UpdateSourceTrigger=PropertyChanged}"
                                             Width="60"
                                             Foreground="White" Background="#3F3F46"
                                             BorderBrush="#555555" BorderThickness="1"
                                             FontSize="11" Padding="2"
                                             TextAlignment="Right"
                                             IsEnabled="{Binding HasModel, Mode=OneWay}"
                                             Tag="Z"
                                             local:DraggableNumberBehavior.IsEnabled="True"
                                             local:DraggableNumberBehavior.Sensitivity="0.05" />
                                </StackPanel>
                            </StackPanel>

                            <!-- ════════════════════════════════════════════ -->
                            <!-- ROTATION (DEGREES)                           -->
                            <!-- ════════════════════════════════════════════ -->
                            <StackPanel Margin="5">
                                <TextBlock Text="Rotation" Foreground="#007ACC"
                                           FontWeight="SemiBold" FontSize="12"
                                           Margin="0,4,0,2" />

                                <!-- X -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                    <TextBlock Text="X:" Foreground="#CCCCCC"
                                               FontSize="11" Width="16" />
                                                                        <TextBox Text="{Binding RotX, StringFormat=F3, UpdateSourceTrigger=PropertyChanged}"
                                             Width="60"
                                             Foreground="White" Background="#3F3F46"
                                             BorderBrush="#555555" BorderThickness="1"
                                             FontSize="11" Padding="2"
                                             TextAlignment="Right"
                                             IsEnabled="{Binding HasModel, Mode=OneWay}"
                                             Tag="X"
                                             local:DraggableNumberBehavior.IsEnabled="True"
                                             local:DraggableNumberBehavior.Sensitivity="0.1" />
                                </StackPanel>

                                <!-- Y -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                    <TextBlock Text="Y:" Foreground="#CCCCCC"
                                               FontSize="11" Width="16" />
                                                                        <TextBox Text="{Binding RotY, StringFormat=F3, UpdateSourceTrigger=PropertyChanged}"
                                             Width="60"
                                             Foreground="White" Background="#3F3F46"
                                             BorderBrush="#555555" BorderThickness="1"
                                             FontSize="11" Padding="2"
                                             TextAlignment="Right"
                                             IsEnabled="{Binding HasModel, Mode=OneWay}"
                                             Tag="Y"
                                             local:DraggableNumberBehavior.IsEnabled="True"
                                             local:DraggableNumberBehavior.Sensitivity="0.1" />
                                </StackPanel>

                                <!-- Z -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                    <TextBlock Text="Z:" Foreground="#CCCCCC"
                                               FontSize="11" Width="16" />
                                                                        <TextBox Text="{Binding RotZ, StringFormat=F3, UpdateSourceTrigger=PropertyChanged}"
                                             Width="60"
                                             Foreground="White" Background="#3F3F46"
                                             BorderBrush="#555555" BorderThickness="1"
                                             FontSize="11" Padding="2"
                                             TextAlignment="Right"
                                             IsEnabled="{Binding HasModel, Mode=OneWay}"
                                             Tag="Z"
                                             local:DraggableNumberBehavior.IsEnabled="True"
                                             local:DraggableNumberBehavior.Sensitivity="0.1" />
                                </StackPanel>
                            </StackPanel>


                            <!-- ════════════════════════════════════════════ -->
                            <!-- SCALE                                        -->
                            <!-- ════════════════════════════════════════════ -->
                            <StackPanel Margin="5">
                                <TextBlock Text="Scale" Foreground="#007ACC"
                                           FontWeight="SemiBold" FontSize="12"
                                           Margin="0,4,0,2" />

                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                                                        <TextBox Text="{Binding Scale, StringFormat=F3, UpdateSourceTrigger=PropertyChanged}"
                                             Width="60"
                                             Foreground="White" Background="#3F3F46"
                                             BorderBrush="#555555" BorderThickness="1"
                                             FontSize="11" Padding="2"
                                             TextAlignment="Right"
                                             IsEnabled="{Binding HasModel, Mode=OneWay}"
                                             local:DraggableNumberBehavior.IsEnabled="True"
                                             local:DraggableNumberBehavior.Sensitivity="0.02"
                                             local:DraggableNumberBehavior.Minimum="0.01" />
                                </StackPanel>
                            </StackPanel>
                        </WrapPanel>
                                                <WrapPanel>
                                                        <!-- Reset button -->
                            <Button Content="↺ Reset"
                                    Command="{Binding ResetTransformCommand}"
                                    IsEnabled="{Binding HasModel, Mode=OneWay}"
                                    Margin="5" Padding="6,3"
                                    FontSize="11" Height="24" />
                            <!-- Place on Ground button -->
                            <Button Content="⬇ Place on Ground"
                                    Command="{Binding PlaceOnGroundCommand}"
                                    IsEnabled="{Binding HasModel, Mode=OneWay}"
                                    Margin="5" Padding="6,3"
                                    FontSize="11" Height="24" />
                        </WrapPanel>

                    </StackPanel>


                </ScrollViewer>
            </Grid>
        </DockPanel>
    </Border>
</UserControl>