<UserControl x:Class="ModelViewer.Controls.SceneModelPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ModelViewer.Converters"
             x:ClassModifier="internal"
             Background="#2D2D30">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Border Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="4">
        <DockPanel>
            <!-- ── Collapsible Header ── -->
            <Border DockPanel.Dock="Top" Background="#252528"
                    BorderBrush="#3F3F46" BorderThickness="0,0,0,1"
                    Padding="5,4">
                <DockPanel>
                    <!-- Collapse toggle (right side) -->
                    <Button x:Name="CollapseBtn"
                            Command="{Binding ToggleExpandCommand}"
                            DockPanel.Dock="Right"
                            Width="18" Height="18">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource CollapseToggleButtonStyle}">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="0"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <RotateTransform Angle="-90"/>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <!-- Title -->
                    <TextBlock Text="Scene Models" Foreground="White"
                               FontWeight="SemiBold" FontSize="12"
                               VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- ── Collapsible Body ── -->
            <Grid x:Name="ContentGrid"
                  Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                                <!-- Add button row -->
                <Button Grid.Row="0" Content="+ Add Model"
                        Command="{Binding AddModelCommand}"
                        Margin="5,4,5,2" Padding="3,2"
                        FontSize="10" Height="20"/>

                                <!-- Model list -->
                <ListBox x:Name="ModelListBox" Grid.Row="1"
                         ItemsSource="{Binding Models}"
                         SelectedItem="{Binding SelectedModel}"
                         Background="#2D2D30"
                         BorderBrush="#3F3F46"
                         Foreground="White"
                         SelectionMode="Single"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         BorderThickness="0"
                         Margin="0,0,0,0">
                    <ListBox.InputBindings>
                        <KeyBinding Key="Delete" Command="{Binding RemoveSelectedCommand}" />
                    </ListBox.InputBindings>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="3,1">
                                <TextBlock Text="{Binding DisplayName}"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           FontSize="11"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding FilePath}"
                                           Foreground="#888888"
                                           FontSize="9"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Remove Selected"
                                      Command="{Binding PlacementTarget.DataContext.RemoveSelectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      InputGestureText="Del" />
                            <MenuItem Header="Remove All"
                                      Command="{Binding PlacementTarget.DataContext.RemoveAllCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        </ContextMenu>
                    </ListBox.ContextMenu>
                </ListBox>

                                <!-- Remove button -->
                <Button Grid.Row="2" Content="🗑 Remove"
                        Command="{Binding RemoveSelectedCommand}"
                        Margin="5,2,5,4" Padding="3,1"
                        FontSize="10" Height="20"/>
            </Grid>
        </DockPanel>
    </Border>
</UserControl>


