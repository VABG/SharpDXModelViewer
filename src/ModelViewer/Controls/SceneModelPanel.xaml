<UserControl x:Class="ModelViewer.Controls.SceneModelPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:ClassModifier="internal"
             Width="250"
             Background="#2D2D30">
    <Border Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="4">
        <DockPanel>
            <!-- Header with title and add button -->
            <Border DockPanel.Dock="Top" Background="#252528" 
                    BorderBrush="#3F3F46" BorderThickness="0,0,0,1"
                    Padding="10,8">
                <StackPanel>
                    <TextBlock Text="Scene Models" Foreground="White"
                               FontWeight="Bold" FontSize="14" Margin="0,0,0,4" />
                    <Button Content="➕ Add Model"
                            Click="OnAddModel_Click" Margin="0,2,0,0" />
                </StackPanel>
            </Border>

                        <!-- Remove button at the bottom -->
            <Button Content="🗑️ Remove Selected"
                    DockPanel.Dock="Bottom"
                    Click="OnRemoveSelected_Click"
                    Margin="8,4,8,6"
                    Padding="4,2"
                    FontSize="11"
                    Height="24" />

            <!-- Model list -->
            <ListBox x:Name="ModelListBox"
                     Background="#2D2D30"
                     BorderBrush="#3F3F46"
                     Foreground="White"
                     SelectionMode="Single"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4,2">
                            <TextBlock Text="{Binding DisplayName}"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding FilePath}"
                                       Foreground="#888888"
                                       FontSize="10"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Remove Selected" 
                                  Click="OnRemoveSelected_Click"
                                  InputGestureText="Del" />
                        <MenuItem Header="Remove All" 
                                  Click="OnRemoveAll_Click" />
                    </ContextMenu>
                </ListBox.ContextMenu>
            </ListBox>
        </DockPanel>
    </Border>
</UserControl>
