<UserControl x:Class="ModelViewer.Controls.SceneModelPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:ClassModifier="internal"
                          Width="200"
             Background="#2D2D30">
    <Border Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="4">
        <DockPanel>
            <!-- ── Collapsible Header ── -->
            <Border DockPanel.Dock="Top" Background="#252528"
                    BorderBrush="#3F3F46" BorderThickness="0,0,0,1"
                    Padding="5,4">
                <DockPanel>
                    <!-- Collapse toggle (right side) -->
                    <Button x:Name="CollapseBtn"
                            Style="{StaticResource CollapseToggleButtonStyle}"
                            Click="OnCollapseToggle_Click"
                            DockPanel.Dock="Right"
                            Width="18" Height="18"
                            Tag="Expanded"/>
                    <!-- Title -->
                    <TextBlock Text="Scene Models" Foreground="White"
                               FontWeight="SemiBold" FontSize="12"
                               VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- ── Collapsible Body ── -->
            <Grid x:Name="ContentGrid" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                                <!-- Add button row -->
                <Button Grid.Row="0" Content="+ Add Model"
                        Click="OnAddModel_Click"
                        Margin="5,4,5,2" Padding="3,2"
                        FontSize="10" Height="20"/>

                <!-- Model list -->
                <ListBox x:Name="ModelListBox" Grid.Row="1"
                         Background="#2D2D30"
                         BorderBrush="#3F3F46"
                         Foreground="White"
                         SelectionMode="Single"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         BorderThickness="0"
                         Margin="0,0,0,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="3,1">
                                <TextBlock Text="{Binding DisplayName}"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           FontSize="11"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding FilePath}"
                                           Foreground="#888888"
                                           FontSize="9"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Remove Selected"
                                      Click="OnRemoveSelected_Click"
                                      InputGestureText="Del" />
                            <MenuItem Header="Remove All"
                                      Click="OnRemoveAll_Click" />
                        </ContextMenu>
                    </ListBox.ContextMenu>
                </ListBox>

                                <!-- Remove button -->
                <Button Grid.Row="2" Content="🗑 Remove"
                        Click="OnRemoveSelected_Click"
                        Margin="5,2,5,4" Padding="3,1"
                        FontSize="10" Height="20"/>
            </Grid>
        </DockPanel>
    </Border>
</UserControl>
