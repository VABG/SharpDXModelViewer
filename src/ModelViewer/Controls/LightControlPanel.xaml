<UserControl x:Class="ModelViewer.Controls.LightControlPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:ClassModifier="internal"
             Background="#2D2D30">
    <Border Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="4">
        <DockPanel>

            <!-- ── Collapsible Header ── -->
            <Border DockPanel.Dock="Top" Background="#252528"
                    BorderBrush="#3F3F46" BorderThickness="0,0,0,1"
                    Padding="6,5">
                <DockPanel>
                    <!-- Collapse toggle (right side) -->
                    <Button x:Name="CollapseBtn"
                            Style="{StaticResource CollapseToggleButtonStyle}"
                            Click="OnCollapseToggle_Click"
                            DockPanel.Dock="Right"
                            Width="18" Height="18"
                            Tag="Expanded"/>
                    <!-- Title -->
                    <TextBlock Text="Light" Foreground="White"
                               FontWeight="SemiBold" FontSize="12"
                               VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- ── Collapsible Body ── -->
            <Grid x:Name="ContentGrid" Visibility="Visible">
                <StackPanel Margin="8,6">

                    <!-- Yaw component -->
                    <TextBlock Text="Yaw:" Foreground="#CCCCCC" FontSize="11" Margin="0,0,0,2" />
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock x:Name="YawText" Text="45°" Foreground="#CCCCCC"
                                   FontSize="10" DockPanel.Dock="Right" />
                        <Slider x:Name="YawSlider" Minimum="-180" Maximum="180" Value="45"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                ValueChanged="OnSlider_ValueChanged" Height="16" />
                    </DockPanel>

                    <!-- Pitch component -->
                    <TextBlock Text="Pitch:" Foreground="#CCCCCC" FontSize="11" Margin="0,0,0,2" />
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock x:Name="PitchText" Text="45°" Foreground="#CCCCCC"
                                   FontSize="10" DockPanel.Dock="Right" />
                        <Slider x:Name="PitchSlider" Minimum="0" Maximum="180" Value="45"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                ValueChanged="OnSlider_ValueChanged" Height="16" />
                    </DockPanel>
                </StackPanel>
            </Grid>
        </DockPanel>
    </Border>
</UserControl>
