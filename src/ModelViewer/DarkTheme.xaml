<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ======================== Colors ======================== -->
    <SolidColorBrush x:Key="MenuBackgroundBrush" Color="#2D2D30" />
    <SolidColorBrush x:Key="MenuBorderBrush" Color="#3E3E42" />
    <SolidColorBrush x:Key="MenuForegroundBrush" Color="White" />
    <SolidColorBrush x:Key="MenuHighlightBrush" Color="#007ACC" />
    <SolidColorBrush x:Key="MenuSeparatorBrush" Color="#3E3E42" />

    <!-- ======================== ContextMenu Template ======================== -->
    <!-- Replaces the entire built-in template so borders are fully under our control -->
    <ControlTemplate x:Key="ContextMenuTemplate" TargetType="ContextMenu">
        <Border Background="{StaticResource MenuBackgroundBrush}"
                BorderBrush="{StaticResource MenuBorderBrush}"
                BorderThickness="1"
                Padding="2">
            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" />
        </Border>
    </ControlTemplate>

    <!-- ======================== Top-Level MenuItem (menu bar) ======================== -->
    <ControlTemplate x:Key="TopLevelMenuItemTemplate" TargetType="MenuItem">
        <Grid>
            <Border x:Name="Border"
                    Background="Transparent"
                    Padding="6,2">
                <ContentPresenter ContentSource="Header"
                                  RecognizesAccessKey="True"
                                  Margin="0,1" />
            </Border>
            <!-- Popup hosts the dropdown submenu items (non-visual, doesn't affect layout) -->
            <Popup x:Name="SubMenuPopup"
                   Placement="Bottom"
                   HorizontalOffset="2"
                   AllowsTransparency="True"
                   StaysOpen="False"
                   IsOpen="False"
                   PopupAnimation="Fade">
                <Border Background="{StaticResource MenuBackgroundBrush}"
                        BorderBrush="{StaticResource MenuBorderBrush}"
                        BorderThickness="1"
                        Padding="2">
                    <StackPanel IsItemsHost="True"
                                KeyboardNavigation.DirectionalNavigation="Cycle" />
                </Border>
            </Popup>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{StaticResource MenuHighlightBrush}" />
            </Trigger>
            <Trigger Property="IsSubmenuOpen" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{StaticResource MenuHighlightBrush}" />
                <Setter TargetName="SubMenuPopup" Property="IsOpen" Value="True" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- ======================== Submenu Header MenuItem (has dropdown arrow) ======================== -->
    <ControlTemplate x:Key="SubmenuHeaderTemplate" TargetType="MenuItem">
        <Grid>
            <Border x:Name="Border"
                    Background="Transparent"
                    Padding="6,2">
                <StackPanel Orientation="Horizontal">
                    <ContentPresenter ContentSource="Header"
                                      RecognizesAccessKey="True"
                                      Margin="0,1" />
                    <Path x:Name="Arrow"
                          Data="M 0 0 L 4 4 L 0 8 Z"
                          Fill="{StaticResource MenuForegroundBrush}"
                          Margin="16,0,0,0"
                          VerticalAlignment="Center" />
                </StackPanel>
            </Border>
            <!-- Popup hosts the nested submenu items (non-visual, doesn't affect layout) -->
            <Popup x:Name="SubMenuPopup"
                   Placement="Right"
                   HorizontalOffset="-2"
                   AllowsTransparency="True"
                   StaysOpen="False"
                   IsOpen="False"
                   PopupAnimation="Fade">
                <Border Background="{StaticResource MenuBackgroundBrush}"
                        BorderBrush="{StaticResource MenuBorderBrush}"
                        BorderThickness="1"
                        Padding="2">
                    <StackPanel IsItemsHost="True"
                                KeyboardNavigation.DirectionalNavigation="Cycle" />
                </Border>
            </Popup>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{StaticResource MenuHighlightBrush}" />
            </Trigger>
            <Trigger Property="IsSubmenuOpen" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{StaticResource MenuHighlightBrush}" />
                <Setter TargetName="SubMenuPopup" Property="IsOpen" Value="True" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- ======================== Submenu Item MenuItem (clickable, no submenu) ======================== -->
    <ControlTemplate x:Key="SubmenuItemTemplate" TargetType="MenuItem">
        <Border x:Name="Border"
                Background="Transparent"
                Padding="6,2">
            <StackPanel Orientation="Horizontal">
                <ContentPresenter ContentSource="Header"
                                  RecognizesAccessKey="True"
                                  Margin="0,1" />
            </StackPanel>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{StaticResource MenuHighlightBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Border" Property="Background" Value="#005A9E" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- ======================== MenuItem Style (selects template by role) ======================== -->
    <Style TargetType="MenuItem">
        <Setter Property="Background" Value="{StaticResource MenuBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource MenuForegroundBrush}" />
        <Setter Property="Template" Value="{StaticResource TopLevelMenuItemTemplate}" />

        <Style.Triggers>
            <!-- Has a dropdown submenu -->
            <Trigger Property="Role" Value="TopLevelHeader">
                <Setter Property="Template" Value="{StaticResource TopLevelMenuItemTemplate}" />
            </Trigger>
            <Trigger Property="Role" Value="SubmenuHeader">
                <Setter Property="Template" Value="{StaticResource SubmenuHeaderTemplate}" />
            </Trigger>
            <!-- Clickable item -->
            <Trigger Property="Role" Value="TopLevelItem">
                <Setter Property="Template" Value="{StaticResource TopLevelMenuItemTemplate}" />
            </Trigger>
            <Trigger Property="Role" Value="SubmenuItem">
                <Setter Property="Template" Value="{StaticResource SubmenuItemTemplate}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ======================== Separator Style ======================== -->
    <Style x:Key="MenuItemSeparatorStyle" TargetType="Separator">
        <Setter Property="Margin" Value="4,2" />
        <Setter Property="Background" Value="{StaticResource MenuSeparatorBrush}" />
        <Setter Property="Height" Value="1" />
    </Style>

    <!-- ======================== ContextMenu Style ======================== -->
    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="{StaticResource MenuBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource MenuForegroundBrush}" />
        <Setter Property="Template" Value="{StaticResource ContextMenuTemplate}" />
    </Style>

    <!-- ======================== Menu (menu bar) Style ======================== -->
    <Style TargetType="Menu">
        <Setter Property="Background" Value="{StaticResource MenuBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource MenuForegroundBrush}" />
    </Style>

    <!-- ======================== Slider Style ======================== -->
    <Style TargetType="Slider">
        <Setter Property="Foreground" Value="#007ACC" />
        <Setter Property="Background" Value="#3F3F46" />
    </Style>

    <!-- ======================== Collapse Toggle Button ======================== -->
    <Style x:Key="CollapseToggleButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="18" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="#AAAAAA" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderThickness="0">
                        <Path x:Name="Chevron"
                              Data="M 2 0 L 6 4 L 2 8"
                              Stroke="{TemplateBinding Foreground}"
                              StrokeThickness="1.5"
                              StrokeLineJoin="Round"
                              StrokeEndLineCap="Round"
                              StrokeStartLineCap="Round"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ======================== Button Style ======================== -->
    <Style TargetType="Button">
        <Setter Property="Background" Value="#3F3F46" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="BorderBrush" Value="#555555" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#007ACC" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#005A9E" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>