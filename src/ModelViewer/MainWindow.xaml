<Window x:Class="ModelViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="3D Model Viewer" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel>
        <!-- Menu bar for model loading -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open Model..." Click="OpenModel_Click" />
                <Separator Style="{StaticResource MenuItemSeparatorStyle}"/>
                <MenuItem Header="E_xit" Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Reset Camera" Click="ResetCamera_Click" />
            </MenuItem>
        </Menu>

        <!-- Status bar showing FPS and model info -->
        <StatusBar DockPanel.Dock="Bottom" Background="#2D2D30" Foreground="White">
            <TextBlock x:Name="StatusText" Text="Ready" Margin="5,0" />
            <TextBlock x:Name="FpsText" Text="FPS: --" Margin="100,0,5,0" />
        </StatusBar>

        <!-- Light direction control panel (right side) -->
        <Border DockPanel.Dock="Right" Width="200" Background="#2D2D30" Margin="5"
                BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="4">
            <StackPanel Margin="10">
                <TextBlock Text="Light Direction" Foreground="White"
                           FontWeight="Bold" FontSize="14" Margin="0,0,0,10" />

                <!-- Yaw component -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                    <TextBlock Text="Yaw:" Foreground="#CCCCCC" FontSize="12" Width="35" />
                    <TextBlock x:Name="YawText" Text="45°" Foreground="#CCCCCC" FontSize="12" />
                </StackPanel>
                <Slider x:Name="YawSlider" Minimum="-180" Maximum="180" Value="45"
                        TickFrequency="5" IsSnapToTickEnabled="True"
                        ValueChanged="LightSlider_ValueChanged" Margin="0,0,0,8" />

                <!-- Pitch component -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                    <TextBlock Text="Pitch:" Foreground="#CCCCCC" FontSize="12" Width="35" />
                    <TextBlock x:Name="PitchText" Text="45°" Foreground="#CCCCCC" FontSize="12" />
                </StackPanel>
                <Slider x:Name="PitchSlider" Minimum="0" Maximum="180" Value="45"
                        TickFrequency="5" IsSnapToTickEnabled="True"
                        ValueChanged="LightSlider_ValueChanged" Margin="0,0,0,8" />

                <Separator Background="#3F3F46" Margin="0,8" />

                <TextBlock Text="Direction preview:" Foreground="#999999"
                           FontSize="11" Margin="0,0,0,4" />
                <TextBlock x:Name="DirectionPreview" Text="X: 0.58, Y: -0.58, Z: 0.58"
                           Foreground="#AAAAAA" FontSize="11" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

                <!-- Scene models panel (left side) -->
        <Border DockPanel.Dock="Left" Width="250" Background="#2D2D30" Margin="5"
                BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="4">
            <DockPanel>
                <!-- Header with title and add button -->
                <Border DockPanel.Dock="Top" Background="#252528" 
                        BorderBrush="#3F3F46" BorderThickness="0,0,0,1"
                        Padding="10,8">
                    <StackPanel>
                        <TextBlock Text="Scene Models" Foreground="White"
                                   FontWeight="Bold" FontSize="14" Margin="0,0,0,4" />
                        <Button x:Name="AddModelButton" Content="➕ Add Model"
                                Click="AddModel_Click" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <!-- Model list -->
                <ListBox x:Name="ModelListBox"
                         Background="#2D2D30"
                         BorderBrush="#3F3F46"
                         Foreground="White"
                         SelectionMode="Single"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4,2">
                                <TextBlock Text="{Binding DisplayName}"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding FilePath}"
                                           Foreground="#888888"
                                           FontSize="10"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Remove Selected" 
                                      Click="RemoveSelectedModel_Click"
                                      InputGestureText="Del" />
                            <MenuItem Header="Remove All" 
                                      Click="RemoveAllModels_Click" />
                        </ContextMenu>
                    </ListBox.ContextMenu>
                </ListBox>

                <!-- Remove button at the bottom -->
                <Button x:Name="RemoveModelButton" Content="🗑️ Remove Selected"
                        DockPanel.Dock="Bottom"
                        Click="RemoveSelectedModel_Click"
                        Margin="8,8,8,8" />
            </DockPanel>
        </Border>

        <!-- The 3D rendering surface will be hosted here -->
        <ContentControl x:Name="RenderHost" />
    </DockPanel>
</Window>


